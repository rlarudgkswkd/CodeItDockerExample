# ===================================================================
# Dockerfile.env - 환경변수 활용 버전
# ===================================================================

# 빌드 시점 변수 정의
ARG APP_NAME=cafe-pos-system
ARG APP_VERSION=1.0.0
ARG BUILD_DATE
ARG VCS_REF

# 빌드 스테이지 (이전과 동일)
FROM amazoncorretto:17.0.18-alpine3.23 AS builder
# ... 빌드 과정 생략 ...

# ===================================================================
# 런타임 스테이지
# ===================================================================
FROM amazoncorretto:17.0.18-alpine3.23

ARG APP_NAME
ARG APP_VERSION
ARG BUILD_DATE
ARG VCS_REF

# 빌드 시점 변수를 환경변수로 전환
ENV APP_NAME=${APP_NAME} \
    APP_VERSION=${APP_VERSION}

# 런타임 환경변수 설정 (기본값 포함)
ENV SPRING_PROFILES_ACTIVE=prod \
    SERVER_PORT=8080 \
    JVM_OPTS="-Xms256m -Xmx512m" \
    JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0"

# 메타데이터 라벨 설정
LABEL org.label-schema.name="${APP_NAME}" \
      org.label-schema.version="${APP_VERSION}" \
      org.label-schema.build-date="${BUILD_DATE}" \
      org.label-schema.vcs-ref="${VCS_REF}" \
      org.label-schema.description="Spring Boot Cafe POS System"

WORKDIR /app

# ... 사용자 설정 및 파일 복사 ...
# JAR 복사 (이거 핵심)
COPY build/libs/*.jar app.jar

CMD ["java", "-jar", "app.jar"]
